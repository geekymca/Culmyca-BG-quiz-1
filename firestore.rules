rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidResult(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.rollNumber is string && data.rollNumber.size() > 0 && data.rollNumber.size() < 100 &&
             data.branch is string && data.branch.size() > 0 && data.branch.size() < 200 &&
             data.course is string && data.course.size() > 0 && data.course.size() < 200 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 8 && data.phoneNumber.size() <= 20 &&
             data.score is number && data.score >= 0 &&
             data.totalQuestions is number && data.totalQuestions > 0 &&
             data.timeTaken is number && data.timeTaken >= 0 &&
             data.timestamp is timestamp;
    }

    // Results collection
    match /results/{resultId} {
      allow create: if isValidResult(request.resource.data);
      allow read: if true; 
      allow delete: if true; // Enabled for admin portal
      allow update: if false;
    }
  }
}
